# Copy this file to `.env` and fill in values as needed. `.env` is gitignored.

# Image generation uses the OpenAI Images API (gpt-image-1). Required to generate images.
OPENAI_API_KEY=your-key-here

# The creative/layout/prompt steps default to the local `claude -p` CLI (no key needed).
# Only set this if you switch that backend to the Anthropic API (DUNGEON_LLM_BACKEND=api).
ANTHROPIC_API_KEY=your-key-here

# Backend for the creative/layout/prompt steps: "claudecode" (default) or "api"
# DUNGEON_LLM_BACKEND=claudecode
